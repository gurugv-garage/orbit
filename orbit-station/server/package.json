{
  "name": "@orbit-station/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "orbit-station backend: raw-WS hub + bus + modules",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --ignore './.data/**' --ignore './src/tasks/generated/**' src/main.ts",
    "start": "tsx src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test --test-force-exit",
    "certs": "node scripts/gen-certs.mjs",
    "smoke": "tsx src/dev/smoke-client.ts",
    "smoke:media": "tsx src/dev/fake-dock-media.ts",
    "smoke:brain": "tsx src/dev/fake-phone.ts",
    "smoke:task": "tsx src/dev/smoke-task.ts",
    "slack:check": "tsx src/dev/slack-check.ts",
    "e2e:console-tasks": "node src/dev/e2e-console-tasks.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.79.1",
    "@earendil-works/pi-ai": "^0.79.1",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/face-api": "^1.7.15",
    "better-sqlite3": "^11.10.0",
    "opusscript": "^0.1.1",
    "werift": "^0.23.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "playwright": "^1.59.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
