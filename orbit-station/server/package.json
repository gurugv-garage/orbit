{
  "name": "@orbit-station/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "orbit-station backend: raw-WS hub + bus + modules",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "tsx watch src/main.ts",
