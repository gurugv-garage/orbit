{
  "name": "orbit-station",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "orbit central control + observability plane (replaces plat)",
  "engines": { "node": ">=22" },
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm -w server run dev",
    "dev:web": "npm -w web run dev",
    "smoke": "npm -w server run smoke",
    "build": "npm -w web run build",
    "start": "npm -w server run start",
    "typecheck": "npm -w server run typecheck && npm -w web run typecheck",
    "certs": "npm -w server run certs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
