#!/usr/bin/env bash
# Patch ext/.../navigation.yaml with our deltas:
#  - inflation_radius 0.7 -> 0.25 (tight sim worlds need less inflation)
#  - add /camera/depth/color/points as a 2nd costmap observation source
# Idempotent. Run after bin/sync (called automatically by bin/ws-build).
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
F="$ROOT/ext/linorobot2/linorobot2_navigation/config/navigation.yaml"
if [[ ! -f "$F" ]]; then
  echo "[patch-nav-yaml] no file at $F (run bin/sync first)"
  exit 0
fi

# Use Python for YAML-aware edits — sed gets ugly when adding multi-line blocks.
python3 - "$F" <<'PY'
import sys, re
path = sys.argv[1]
with open(path) as f:
    text = f.read()

# 1) inflation_radius: 0.7 / 0.70  ->  0.25
text = re.sub(r'inflation_radius:\s*0\.70?$', 'inflation_radius: 0.25', text, flags=re.MULTILINE)

# 2) Add pointcloud as 2nd observation source.
#    Pattern: each costmap block has "observation_sources: scan" followed by a scan: block.
#    We rewrite to "observation_sources: scan pointcloud" and append a pointcloud: block
#    after the scan: block. Idempotent: skip if already contains "pointcloud".
def patch_block(text: str, marker: str) -> str:
    # Find "observation_sources: scan" lines that don't already include pointcloud
    pattern = re.compile(r'^(\s*)observation_sources:\s*scan\s*$', re.MULTILINE)
    def add_pc(m):
        indent = m.group(1)
        return f"{indent}observation_sources: scan pointcloud"
    if 'pointcloud' in text:
        # already patched
        return text
    text = pattern.sub(add_pc, text)
    # Now append a pointcloud config block after each existing "scan:" subblock.
    # Find "        scan:\n          topic: /scan\n..." and insert pointcloud block after the
    # full scan block (terminated by next line with different indent or blank line).
    # Simpler heuristic: insert pointcloud block right after the line "raytrace_max_range: 3.0"
    # that follows each scan block.
    insertion_done = []
    def make_pc_block(indent: str) -> str:
        return (
            f"{indent}pointcloud:\n"
            f"{indent}  topic: /camera/depth/color/points\n"
            f"{indent}  max_obstacle_height: 2.0\n"
            f"{indent}  min_obstacle_height: 0.05\n"
            f"{indent}  clearing: True\n"
            f"{indent}  marking: True\n"
            f"{indent}  data_type: \"PointCloud2\"\n"
            f"{indent}  raytrace_max_range: 3.0\n"
            f"{indent}  raytrace_min_range: 0.0\n"
            f"{indent}  obstacle_max_range: 2.5\n"
            f"{indent}  obstacle_min_range: 0.0\n"
        )
    # Find lines like "          raytrace_max_range: 3.0" that conclude a scan block.
    lines = text.split("\n")
    out = []
    i = 0
    while i < len(lines):
        out.append(lines[i])
        # Check if this line is "raytrace_max_range" inside a "scan:" subblock
        m = re.match(r'^(\s+)raytrace_max_range:\s*3\.0\s*$', lines[i])
        # We want to confirm this raytrace_max_range belongs to the scan: block by
        # looking up a few lines.
        if m:
            scan_indent = m.group(1)
            # Look back up to ~6 lines for "scan:" with shallower indent
            scan_found = False
            for j in range(max(0, i-8), i):
                if re.match(rf'^{scan_indent[:-2]}scan:\s*$', lines[j]):
                    scan_found = True
                    break
            if scan_found:
                out.append(make_pc_block(scan_indent[:-2]).rstrip("\n"))
        i += 1
    text = "\n".join(out)
    return text

text = patch_block(text, "")

# 3) Top-level observation_sources for the costmap_filter_info / collision_monitor
text = re.sub(
    r'^(\s*)observation_sources:\s*\["scan"\]\s*$',
    r'\1observation_sources: ["scan", "pointcloud"]',
    text, flags=re.MULTILINE
)

with open(path, "w") as f:
    f.write(text)
print(f"[patch-nav-yaml] patched {path}")
PY

echo "[patch-nav-yaml] done"
