#!/usr/bin/env bash
# Publish /cmd_vel for 4 seconds — forward + turn. Verifies sim is responsive.
set +e
docker exec -t rover bash -lc '
  source /opt/ros/jazzy/setup.bash
  timeout 4 ros2 topic pub /cmd_vel geometry_msgs/msg/Twist \
    "{linear: {x: 0.3}, angular: {z: 0.5}}" -r 10 >/dev/null 2>&1
  echo "drove forward+turn for 4 seconds. check /odom in Foxglove."
'
exit 0
