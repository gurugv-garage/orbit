#!/usr/bin/env bash
# Wipe everything: container, image, named volumes, ext/, workspace/, maps/.
# Use to start completely fresh.
set +e
cd "$(dirname "$0")/.."

docker stop rover 2>/dev/null
docker rm rover 2>/dev/null
docker rmi bit2atms/rover:latest 2>/dev/null
docker volume rm rover_ws_src rover_ws_build rover_ws_install rover_ws_log 2>/dev/null

rm -rf ext/* maps/* 2>/dev/null
# Don't wipe workspace/ — it contains helper scripts (sim-stop.sh, status.sh)
# that other bin/ scripts depend on. Those are checked in.

echo "[nuke] container, image, volumes, ext/, maps/ removed."
echo "       workspace/ helper scripts preserved."
echo "       start over with: bin/sync && bin/build && bin/up"
exit 0
