#!/usr/bin/env bash
# Interactive end-to-end smoke test.
#
# At each step you see what/why/expect and choose:
#   [Enter]/y  → run         s → skip         q → quit
#
# Flags:
#   --yes, -y          run every step non-interactively
#   --from N           start at step N (1-6); skip steps 1..N-1
#   --only "1,3,5"     run only listed steps; skip the rest
#
# Steps build on each other (sim running, map saved, nav up, …).
# If you start from a middle step, you're asserting earlier steps already happened.
# A killed script does NOT auto-resume — pick up with --from N where N is the
# next step you want to run.
#
# During a running step:
#   - keystrokes are queued by the OS but are *discarded* before the next prompt
#   - a spinner shows elapsed seconds
#   - the step's stdin is /dev/null so it can't consume your keys
set -uo pipefail
cd "$(dirname "$0")/.."

YES=0
FROM=1
ONLY=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --yes|-y) YES=1; shift ;;
    --from)   FROM="$2"; shift 2 ;;
    --only)   ONLY="$2"; shift 2 ;;
    -h|--help)
      sed -n '2,/^set -uo/p' "$0" | sed 's/^# \{0,1\}//' | head -n -1
      exit 0
      ;;
    *) echo "unknown arg: $1"; exit 2 ;;
  esac
done

# Should the given step number run, given --from and --only?
should_run_step() {
  local n="$1"
  if [[ -n "$ONLY" ]]; then
    # comma-separated list
    [[ ",${ONLY}," == *,${n},* ]]
    return $?
  fi
  (( n >= FROM ))
}

# Restore cursor on any exit (Ctrl-C, error, normal completion).
trap 'printf "\033[?25h"' EXIT

# Drain any pending stdin (keys queued during a long step).
drain_stdin() {
  if [[ -t 0 ]]; then
    while read -r -t 0.001 -n 1 _; do :; done 2>/dev/null || true
  elif [[ -e /dev/tty ]]; then
    while read -r -t 0.001 -n 1 _ </dev/tty; do :; done 2>/dev/null || true
  fi
}

# Run a command with a spinner showing elapsed seconds. Captures stdout to a
# temp file so we can show the tail at the end. Stdin is /dev/null so the
# command can't consume keystrokes intended for the next prompt.
# Usage:   spin "label" -- cmd args...
#   or:    spin "label" --tail N -- cmd args...
spin() {
  local label="$1"; shift
  local tail_n=2
  if [[ "$1" == "--tail" ]]; then tail_n="$2"; shift 2; fi
  [[ "$1" == "--" ]] && shift
  local logfile
  logfile=$(mktemp)
  local start=$SECONDS
  # Run command in background, stdin=/dev/null, stdout/err -> log
  ( "$@" </dev/null >"$logfile" 2>&1 ) &
  local pid=$!
  local chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
  local i=0
  # Hide cursor for nicer rendering
  printf '\033[?25l'
  while kill -0 "$pid" 2>/dev/null; do
    local elapsed=$((SECONDS - start))
    local ch="${chars:i:1}"
    printf '\r  %s  %s  (%ds)' "$ch" "$label" "$elapsed"
    i=$(( (i + 1) % 10 ))
    sleep 0.1
  done
  wait "$pid"
  local rc=$?
  local elapsed=$((SECONDS - start))
  # Clear line, show cursor
  printf '\r\033[K\033[?25h'
  if [[ $rc -eq 0 ]]; then
    printf '  ✓  %s  (%ds)\n' "$label" "$elapsed"
  else
    printf '  ✗  %s  (%ds, exit=%d)\n' "$label" "$elapsed" "$rc"
  fi
  # Show tail of output, indented. Filter out known-harmless noise:
  #   - RTPS_TRANSPORT_SHM init errors (Fast-DDS falls back to UDP)
  #   - ROS_LOCALHOST_ONLY deprecation warnings
  #   - ANSI color escape sequences (cleaner plain-text output)
  if [[ -s "$logfile" ]]; then
    sed -E $'s/\x1b\\[[0-9;]*[A-Za-z]//g' "$logfile" \
      | grep -v -E 'RTPS_TRANSPORT_SHM|ROS_LOCALHOST_ONLY|localhost_only.*will be used' \
      | tail -n "$tail_n" \
      | sed 's/^/      /'
  fi
  rm -f "$logfile"
  return $rc
}

# Simple "sleep with spinner" — same UX as spin, no command.
zzz() {
  local label="$1" secs="$2"
  spin "$label" -- sleep "$secs"
}

# Show a prompt box and ask for input. Drains stdin first so queued keys are
# discarded.
prompt() {
  local title="$1"; shift
  echo
  echo "════════════════════════════════════════════════════════════════"
  echo "  $title"
  echo "────────────────────────────────────────────────────────────────"
  local line
  for line in "$@"; do
    echo "  $line"
  done
  echo "────────────────────────────────────────────────────────────────"
  if [[ $YES -eq 1 ]]; then
    echo "  [auto-yes]"
    return 0
  fi
  drain_stdin
  if [[ ! -t 0 ]] && [[ ! -e /dev/tty ]]; then
    echo "  [no tty — running]"
    return 0
  fi
  local ans
  if [[ -t 0 ]]; then
    read -r -p "  [Enter=run · s=skip · q=quit]  " ans
  else
    read -r -p "  [Enter=run · s=skip · q=quit]  " ans </dev/tty
  fi
  case "${ans:-}" in
    q|Q) echo "  bye."; exit 0 ;;
    s|S) echo "  skipped."; return 1 ;;
    *)   return 0 ;;
  esac
}

# ── Pre-flight ───────────────────────────────────────────────────────
if ! docker ps --format '{{.Names}}' | grep -qx rover; then
  echo "container 'rover' is not running. Run: bin/up"
  exit 1
fi
if ! docker exec -t rover bash -c 'test -f /ws/overlay/test_odom_closure.py'; then
  echo "ERROR: /ws/overlay/ inside the container is empty or missing files."
  echo "       This usually means the bind mount dropped. Fix with:"
  echo "         bin/down && bin/up"
  exit 1
fi
if ! docker exec -t rover bash -c 'test -f /ws/install/setup.bash'; then
  echo "ERROR: /ws/install/setup.bash missing — linorobot2 not built."
  echo "       Run: bin/ws-build"
  exit 1
fi

# Wrapper: skip a step entirely if --from or --only excludes it.
step() {
  local n="$1"
  if ! should_run_step "$n"; then
    echo
    echo "── Step $n/6: skipped (filtered by --from/--only) ──"
    return 1
  fi
  return 0
}

# ── 1) Sim restart ───────────────────────────────────────────────────
if step 1 && prompt "Step 1/6  Restart Gazebo sim cleanly" \
  "what:    bin/sim-stop (best-effort) then bin/sim, wait ~14s." \
  "why:     fresh /odom (0,0,0), fresh map frame. Avoids stale state." \
  "expect:  'sim launched headless (world=playground)' then a 14s wait."; then
  spin "stopping sim" -- bash -c 'bin/sim-stop || true'
  spin "launching sim" -- bin/sim
  zzz "waiting for Gazebo to settle" 14
fi

# ── 2) Odom test ─────────────────────────────────────────────────────
if step 2 && prompt "Step 2/6  Odometry closure check (1m square)" \
  "what:    python3 /ws/overlay/test_odom_closure.py" \
  "why:     proves /cmd_vel reaches motors and /odom integrates correctly." \
  "expect:  closure < 5 cm. Bigger error = something is off with the sim."; then
  spin "driving 1m square (~30s)" --tail 3 -- \
    docker exec -t rover bash -lc \
      'source /opt/ros/jazzy/setup.bash && python3 /ws/overlay/test_odom_closure.py'
fi

# ── 3) SLAM start ────────────────────────────────────────────────────
if step 3 && prompt "Step 3/6  Start SLAM (slam_toolbox + Nav2)" \
  "what:    bin/slam — launches alongside the running sim." \
  "why:     we need a map of the world before Nav2 can plan paths in it." \
  "expect:  /map, /global_costmap, /local_costmap topics appear."; then
  spin "starting SLAM" -- bin/slam
  zzz "waiting for slam_toolbox to be ready" 8
fi

# ── 4) Coverage drive ────────────────────────────────────────────────
if step 4 && prompt "Step 4/6  Drive a 60s bounded coverage pattern" \
  "what:    python3 /ws/overlay/bounded_coverage.py 60" \
  "why:     SLAM only maps what the LIDAR has seen. We drive the bot in a" \
  "         bounded loop and then back to origin so the saved map contains" \
  "         the start pose (Nav2 needs that)." \
  "expect:  ~60s of wandering + 30s returning. Bot ends within 0.3m of start."; then
  spin "coverage drive (60s + return)" --tail 3 -- \
    docker exec -t rover bash -lc \
      'source /opt/ros/jazzy/setup.bash && python3 /ws/overlay/bounded_coverage.py 60'
fi

# ── 5) Save map ──────────────────────────────────────────────────────
if step 5 && prompt "Step 5/6  Save the map → maps/demo_map.{pgm,yaml}" \
  "what:    bin/save-map demo_map  (writes to host-side maps/ folder)" \
  "why:     a saved map is needed by Nav2's localization (AMCL)." \
  "expect:  '[save-map] saved: maps/demo_map.{pgm,yaml}'"; then
  spin "saving map" -- bin/save-map demo_map
fi

# ── 6) Nav with saved map ───────────────────────────────────────────
if step 6 && prompt "Step 6/6  Restart nav stack with the saved map + initialize AMCL" \
  "what:    bin/nav-stop  →  bin/nav demo_map  →  init_amcl.py" \
  "why:     during SLAM, the map is built live. For autonomous nav, we load" \
  "         the saved map and use AMCL (Adaptive Monte Carlo Localization)." \
  "         init_amcl.py publishes the bot's current pose to AMCL." \
  "expect:  Nav2 nodes come up; /initialpose published."; then
  spin "stopping SLAM/Nav stack" -- bash -c 'bin/nav-stop || true'
  zzz "waiting" 3
  spin "launching Nav2 with saved map" -- bin/nav demo_map
  zzz "waiting for Nav2 lifecycle" 14
  spin "initializing AMCL" -- \
    docker exec -t rover bash -lc \
      'source /opt/ros/jazzy/setup.bash && python3 /ws/overlay/init_amcl.py'
  zzz "settling" 3
fi

echo
echo "════════════════════════════════════════════════════════════════"
echo "  demo complete"
echo "────────────────────────────────────────────────────────────────"
echo "  Foxglove → ws://localhost:8765"
echo "  (import workspace/foxglove-layout-v5.json on first use)"
echo "  bin/help shows all commands"
