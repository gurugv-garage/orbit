#!/usr/bin/env bash
# Save current SLAM map. Usage: bin/save-map <name>
# Output: maps/<name>.pgm + maps/<name>.yaml
#
# map_saver_cli sometimes exits non-zero even on success (lifecycle teardown
# noise). We retry once and then verify by checking the file exists.
set -uo pipefail
NAME="${1:-home_map}"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

run_save() {
  docker exec -t rover bash -lc "
    source /opt/ros/jazzy/setup.bash
    source /ws/install/setup.bash
    cd /ws/maps
    ros2 run nav2_map_server map_saver_cli -f '${NAME}'
  " 2>&1 | tail -1
}

run_save || true
if [[ ! -f "$ROOT/maps/${NAME}.yaml" ]]; then
  echo "[save-map] first attempt didn't produce a file, retrying..."
  sleep 2
  run_save || true
fi

if [[ -f "$ROOT/maps/${NAME}.yaml" && -f "$ROOT/maps/${NAME}.pgm" ]]; then
  echo "[save-map] saved: maps/${NAME}.{pgm,yaml}"
  exit 0
else
  echo "[save-map] FAILED — no map at maps/${NAME}.{pgm,yaml}"
  exit 1
fi
