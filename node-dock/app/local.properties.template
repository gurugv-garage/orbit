# Copy to local.properties (gitignored) and fill in. The Android build reads
# these at compile time (see app/build.gradle.kts buildConfigField).

# Android SDK location on this machine.
sdk.dir=/Users/<you>/Library/Android/sdk

# --- orbit-station (the dock's BRAIN) ---
# The LLM loop, body motion, and face memory run in orbit-station; the phone
# is perception + actuation. LLM model/persona + API keys are configured at
# the STATION (config console / orbit-station/.env), not here.
# AVD → host: ws://10.0.2.2:8099/ws.  Physical device: ws://<laptop-lan-ip>:8099/ws.
# Empty → no brain; the face/perception UX still runs.
STATION_URL=
# DOCK_NAME is now assigned at RUNTIME (docs/decision-traces/runtime-dock-binding.md):
# leave it EMPTY and the device dials in "unclaimed" — claim it onto a dock in the
# station console (Overview → Unclaimed devices). The binding survives app
# uninstall/reinstall (keyed by ANDROID_ID). Set a value only as a dev override to
# self-bind without the console.
DOCK_NAME=

# Wake-word (optional): picovoice.ai console key.
PORCUPINE_ACCESS_KEY=

# --- OTA release signing (docs/OTA.md §5.1) ---
# Required to produce a SIGNED release APK that can self-update over the air.
# Generate the keystore with: orbit-station/scripts/gen-keystore.sh (it prints
# these lines). If left blank, the release build falls back to the debug key —
# it builds, but the APK is NOT installable as an OTA update. Never commit the
# keystore or these passwords.
RELEASE_STORE_FILE=
RELEASE_STORE_PASSWORD=
RELEASE_KEY_ALIAS=dock
RELEASE_KEY_PASSWORD=
