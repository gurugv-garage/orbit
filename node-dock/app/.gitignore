# Big ONNX models — fetched on demand by scripts/fetch-models.sh.
# Silero VAD (~2 MB) is committed; FER+ (~35 MB) is not.
app/src/main/assets/models/emotion_ferplus.onnx

# local debug dumps (camera frames, screenshots) — at module root (app/tmp/)
tmp/
app/tmp/

# Benchmark results: NAMED snapshots + index.json are committed as durable
# history (so prompt v1 vs v2 stays comparable). The transient mirror + raw logs
# are local-only.
bench/results/latest.json
bench/results/*.log
