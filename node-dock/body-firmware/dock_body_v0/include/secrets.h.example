// Copy this file to `secrets.h` and fill in your values — OR let
// orbit-station/scripts/bootstrap-body.sh generate it from prompts.
// `secrets.h` is gitignored — your real values never get committed.
//
// XIAO ESP32-S3 is 2.4 GHz only. Use a 2.4 GHz SSID; don't point it at
// a band-steering router's combined 5 GHz network unless you've split
// the bands.

#pragma once

#define WIFI_SSID     "your-2.4ghz-ssid"
#define WIFI_PASSWORD "your-password"

// orbit-station link (docs/OTA.md). The body dials this to register + receive
// OTA offers. Empty → standalone (the phone-facing BodyLink server on :17317
// still works; no station, no OTA). Laptop on the same LAN:
//   ws://<laptop-lan-ip>:8099/ws
#define STATION_URL   ""
// The named dock this body belongs to (groups app + firmware at the station).
#define DOCK_NAME     "anne-bot"
