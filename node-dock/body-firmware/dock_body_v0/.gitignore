# PlatformIO build artifacts
.pio/

# ESP-IDF Component Manager: fetched managed deps + lock (re-fetched on build).
# The dependency is declared in src/idf_component.yml — that IS committed.
managed_components/
dependencies.lock

# IDE
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

