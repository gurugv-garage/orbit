# --- Python / general ---
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
env/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo
.ipynb_checkpoints/

# --- Robot / simulation outputs ---
*.bag
*.db3
logs/
runs/
.playwright-mcp/
outputs/

# --- node-rover: vendored external clones (re-clone, don't track) ---
node-rover/ext/

# --- Android (node-dock/app) ---
*.apk
*.aar
*.ap_
*.aab
.gradle/
local.properties
captures/
.externalNativeBuild/
.cxx/
*.jks
*.keystore
*.log
.kotlin/

# Big ONNX models — fetched on demand (see node-dock/app scripts).
node-dock/app/app/src/main/assets/models/emotion_ferplus.onnx
# Speaker-embedding model for the perception sidecar (--embed-model; wget from
# github.com/k2-fsa/sherpa-onnx releases, tag speaker-recongition-models).
models/perception-sidecar/*.onnx

# Local debug dumps (camera frames, screenshots).
tmp/
node-dock/app/app/tmp/

# Benchmark run outputs — committed snapshots stay; transient mirror + logs don't.
node-dock/app/bench/results/latest.json
node-dock/app/bench/results/*.log

# --- ESP-IDF / PlatformIO firmware build (node-dock/body-firmware) ---
.pio/
.webrtc-aar/
.webrtc-src/

# Scratch/dictation notes — transient thinking, not tracked.
scrap
scrap-*

# E2E (and any) cloud provider API credentials — NEVER commit.
ops/e2e.keys
ops/*.keys
ops/*.secret
